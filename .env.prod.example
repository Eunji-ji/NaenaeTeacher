# Copy this file to .env.prod and replace every change-this value.
# Never commit .env.prod.

# Spring Boot
SPRING_PROFILES_ACTIVE=prod
PORT=8081
JAVA_OPTS=-Xms128m -Xmx512m

# PostgreSQL container
POSTGRES_DB=naenae_teacher
POSTGRES_USER=naenae
POSTGRES_PASSWORD=change-this-db-password

# Spring datasource (the Compose file enforces the internal db hostname)
DB_URL=jdbc:postgresql://db:5432/naenae_teacher
DB_USERNAME=naenae
DB_PASSWORD=change-this-db-password
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1

# Security: use a cryptographically random value of at least 32 characters.
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-32-characters

# Persistent uploads inside the app_uploads Docker volume
ASSIGNMENT_STORAGE_DIR=/var/lib/naenae-teacher/uploads/assignments
NOTICE_STORAGE_DIR=/var/lib/naenae-teacher/uploads/notices
BOARD_STORAGE_DIR=/var/lib/naenae-teacher/uploads/board
PROFILE_STORAGE_DIR=/var/lib/naenae-teacher/uploads/profiles
WEEKLY_TEST_STORAGE_DIR=/var/lib/naenae-teacher/uploads/weekly-tests

# Invitation and signup protection
INVITATION_CODE_VALID_DAYS=30
INVITATION_CODE_MAX_USES=100
SIGNUP_LOOKUP_LIMIT_PER_MINUTE=30
SIGNUP_LIMIT_PER_TEN_MINUTES=10

# Legal page operator details
SERVICE_NAME=NaenaeTeacher
SERVICE_OPERATOR_NAME=change-this-operator-name
PRIVACY_CONTACT_EMAIL=change-this-privacy-email@example.com
